// This is your Prisma schema file.
// Run: npx prisma migrate dev --name add_all_missing_tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum NotificationType {
  MESSAGE
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  PAYMENT_RECEIVED
  SYSTEM
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products         Product[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
  payments         Payment[]
  uploadRequests   UploadRequest[]

  @@map("users")
}

// ─── Categories ───────────────────────────────────────────────────────────────
// Canonical list of product categories managed by admins.
// slug: URL-safe unique key e.g. "home-kitchen" for "Home & Kitchen"

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String?  // legacy single-image field kept for backward compatibility
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sellerId Int
  seller   User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  // Replaces old plain-text category string with FK to categories table
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images        ProductImage[]
  uploadRequest UploadRequest?

  @@map("products")
}

// ─── Product Images ───────────────────────────────────────────────────────────
// One product can have many images.
// isPrimary: the main/cover image shown in listings (only one per product)
// sortOrder: display order — lower numbers appear first

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId   Int
  sender     User @relation("SentMessages",    fields: [senderId],   references: [id], onDelete: Cascade)
  receiverId Int
  receiver   User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id          Int           @id @default(autoincrement())
  amount      Float
  status      PaymentStatus @default(PENDING)
  reference   String?       @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  uploadRequestId Int?           @unique
  uploadRequest   UploadRequest? @relation(fields: [uploadRequestId], references: [id])

  @@map("payments")
}

// ─── Upload Requests / Listing Fees ──────────────────────────────────────────

model UploadRequest {
  id        Int            @id @default(autoincrement())
  status    ApprovalStatus @default(PENDING)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int     @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  adminReview AdminReview?
  payment     Payment?

  @@map("upload_requests")
}

// ─── Admin Reviews / Approvals ────────────────────────────────────────────────

model AdminReview {
  id        Int            @id @default(autoincrement())
  decision  ApprovalStatus
  reason    String?
  createdAt DateTime       @default(now())

  adminId Int

  uploadRequestId Int           @unique
  uploadRequest   UploadRequest @relation(fields: [uploadRequestId], references: [id], onDelete: Cascade)

  @@map("admin_reviews")
}
